# ドメイン・デプロイ用メモ（パス型: https://ksystemapp.com/kakeibo/）
# コピー: infra/env.deploy.local または deploy-secrets.env（.gitignore 済み。コミットしない）

# ルートドメイン（Route 53 ホストゾーン名・CloudFront の別名）
ROOT_DOMAIN=ksystemapp.com

# 公開 URL（ブラウザで開く家計簿）
APP_URL=https://ksystemapp.com/kakeibo/

# API（App Runner カスタムドメイン）
API_FQDN=api.ksystemapp.com

# Route 53 ホストゾーン ID（Z で始まる文字列）
HOSTED_ZONE_ID=Zxxxxxxxxxxxx

# ACM 証明書（CloudFront 用・必ず us-east-1）。別名は apex のみ
ACM_CERT_ARN_US_EAST_1=arn:aws:acm:us-east-1:ACCOUNT_ID:certificate/UUID

# Terraform 出力
S3_BUCKET_NAME=
CLOUDFRONT_DISTRIBUTION_ID=
