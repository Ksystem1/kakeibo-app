# コピー: cp rds-credentials.auto.tfvars.example rds-credentials.auto.tfvars
# rds-credentials.auto.tfvars は .gitignore 済み。パスワードをコミットしないこと。

manage_rds_credentials_secret = true

rds_credentials = {
  host     = "your-db.xxxxx.ap-northeast-1.rds.amazonaws.com"
  port     = 3306
  username = "admin"
  password = "REPLACE_WITH_STRONG_PASSWORD"
  database = "kakeibo"
}
