{
  "name": "kakeibo",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently -n web,api -c cyan,magenta \"vite\" \"npm run dev:api --prefix backend\"",
    "dev:web": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
