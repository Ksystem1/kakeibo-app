    "deploy:backend": "node infra/scripts/deploy-backend-apprunner.mjs",
    "deploy:prod": "node infra/scripts/deploy-production.mjs",
    "deploy:auto": "node infra/scripts/deploy-and-verify.mjs",
    "verify:login": "node infra/scripts/verify-login.mjs"
