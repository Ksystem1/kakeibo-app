# generate_ad.py 設定例（機密はここに置かないこと）

# 広告テンプレート設定ファイル
AD_CONFIG_PATH=ad_config.json

# 出力先（Zapier/Make が監視するフォルダを指定）
AD_OUTPUT_DIR=automation_output

# daily or random
AD_SELECTION_MODE=daily

# 任意: daily 選択キーを固定したい場合（通常は未設定でOK）
# AD_DAY_KEY=2026-05-06

# 任意: Google Drive 同期クライアントのローカル同期フォルダ
# 例: C:\Users\yourname\Google Drive\marketing_exports
# GOOGLE_DRIVE_EXPORT_DIR=

# 将来 API 連携時の例（コードに直書きしない）
# OPENAI_API_KEY=

