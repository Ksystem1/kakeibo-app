# プロジェクトルートにコピー: copy .env.local.example .env.local
# フロント再起動後に反映（Vite）

# --- API を localhost:3456 に直接つなぐ（Vite プロキシを使わない）---
# backend/.env に API_PATH_PREFIX=/api がある場合は末尾 /api まで含める。
# VITE_API_URL=http://127.0.0.1:3456/api
#
# またはホストだけ指定してプレフィックスを自動付与:
# VITE_API_URL=http://127.0.0.1:3456
# VITE_API_APPEND_PREFIX=1
#
# 一時的に /config だけ別 URL にしたいとき（例: 検証用フルパス）
# VITE_STRIPE_CONFIG_URL=http://127.0.0.1:3456/api/config
