# プロジェクトルートにコピー: copy .env.local.example .env.local
# フロント再起動後に反映（Vite）

# 開発の既定はコード側で http://localhost:3456/api に固定済み（誤った VITE_API_URL を無視）。
# Vite プロキシ（/api）に戻すときだけ:
# VITE_API_USE_VITE_PROXY=1
#
# 別ポートの API を試すとき:
# VITE_API_DEV_BASE_URL=http://127.0.0.1:9999/api
#
# GET /config だけ別 URL:
# VITE_STRIPE_CONFIG_URL=http://127.0.0.1:3456/api/config
