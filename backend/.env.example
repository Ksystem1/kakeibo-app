# Lambda ローカル実行・マイグレーション用。コピーして .env にリネームしパスワードを記入。
# テーブル作成: このフォルダで npm install → npm run db:schema

RDS_HOST=database-1.ch2yqsmikcdn.ap-northeast-1.rds.amazonaws.com
RDS_PORT=3306
RDS_USER=admin
RDS_DATABASE=database-1
RDS_PASSWORD=

# カンマ区切りで複数可。全許可は * （本番はフロントのオリジンを列挙。パスは含めない）
# 本番 SPA: https://ksystemapp.com/kakeibo/ → Origin は https://ksystemapp.com のみ
# フロントを localhost:5173、API を localhost:3456 に直結する開発では、必ず 5173 を含める（Authorization 付き fetch の CORS 用）
CORS_ORIGIN=https://ksystemapp.com,http://localhost:5173,http://127.0.0.1:5173
# 未設定時、RDS_HOST が *.rds.amazonaws.com なら TLS を自動有効化
RDS_SSL=

# ローカル API（npm run dev:api）
API_PORT=3456
NODE_ENV=development
# プロジェクトルートで `npm run dev`（Vite が /api をプロキシ）するとき、ルーティングが /billing/... に届くよう必須
# API_PATH_PREFIX=/api
#
# `https://ksystemapp.com/kakeibo/api/...` のように ALB が /kakeibo 付きで転送する場合、コード側で /kakeibo を剥がしてルーティングする（API_PATH_PREFIX とは別）
#
# 起動時に STRIPE_TEST_PRICE_ID が読めているかターミナルへ出す（本番では通常不要）
# STRIPE_LOG_PRICE_ID_ON_BOOT=1

# 認証（本番では強力なランダム文字列を必ず設定）
JWT_SECRET=change-me-in-production-use-long-random
JWT_EXPIRES_IN=7d
# 開発のみ: X-User-Id ヘッダーを許可
ALLOW_X_USER_ID=true
# 開発のみ: パスワードリセット・招待トークンを JSON に含める
AUTH_DEBUG_TOKEN=false

# --- WebAuthn / 招待URL（本番 ksystemapp.com）---
# NODE_ENV=production 時、未設定でも passkey-webauthn.mjs は https://ksystemapp.com をフォールバックするが、
# 次を明示すると設定ミスを防げる。
# WEBAUTHN_ORIGIN=https://ksystemapp.com
# WEBAUTHN_RP_ID=ksystemapp.com
# WEBAUTHN_ADDITIONAL_ORIGINS=https://www.ksystemapp.com
# フロントのベース（家族招待リンク buildInviteUrl）: PUBLIC_APP_ORIGIN または APP_ORIGIN
# PUBLIC_APP_ORIGIN=https://ksystemapp.com
# CORS は WebAuthn Origin とは別。SPA 用: CORS_ORIGIN=https://ksystemapp.com,https://www.ksystemapp.com

# 本番のみ: フロントから debugForceReceiptTier（無料/有料プロンプトの強制切替）を受け付ける
# RECEIPT_DEBUG_SUBSCRIPTION_TIER=1

# Stripe 前の検証: 指定 users.id を常に subscription active 扱い（カンマ区切り）
# SUBSCRIPTION_FORCE_ACTIVE_USER_IDS=1,2

# --- Stripe（決済・Webhook）---
# 必須: 秘密鍵（テストなら sk_test_... を STRIPE_SECRET_KEY にそのまま設定してよい）
# STRIPE_SECRET_KEY=sk_test_...
# 本番 ECS: GitHub Secret STRIPE_SECRET_KEY は sk_live_...。sk_test_ のままだと Checkout URL が cs_test_ となり本番カード不可。
#
# 必須: Webhook 署名シークレット（ダッシュボード → Webhooks → 署名 whsec_...）
# エンドポイント URL は API ホスト（例: https://api.ksystemapp.com/api/stripe/webhook）。
# https://ksystemapp.com/kakeibo/api/... のようにフロント配信 URL にすると HTML が返り同期されません。
# STRIPE_WEBHOOK_SECRET=whsec_...
#
# GET / の案内用に本番 API の公開オリジンを明示（任意。Host が localhost のとき）
# STRIPE_WEBHOOK_PUBLIC_API_ORIGIN=https://api.ksystemapp.com
#
# 別名で Test 用だけ分けたい場合のフォールバック（上記が空のときのみ使われる）
# STRIPE_TEST_SECRET_KEY=
# STRIPE_TEST_WEBHOOK_SECRET=
#
# Checkout（POST /billing/checkout-session）用のサブスク Price ID
# 秘密鍵が sk_live_ のときは STRIPE_PRICE_ID を優先（両方ある場合に Test の price を誤参照しない）
# sk_test_ のときは STRIPE_TEST_PRICE_ID を優先
# STRIPE_TEST_PRICE_ID=price_...
# STRIPE_PRICE_ID=price_...
#
# リダイレクト URL の Origin 許可（カンマ区切り）。未設定時は localhost + ksystemapp.com
# STRIPE_CHECKOUT_ALLOWED_ORIGINS=http://localhost:5173,https://ksystemapp.com
#
# 任意: Checkout 作成を sk_test_ のみに制限
# STRIPE_CHECKOUT_REQUIRE_TEST_KEY=1
# GitHub Secrets を更新したときは backend/** を push して deploy.yml を再実行する
# Webhook 反映確認は https://api.ksystemapp.com/config の webhookConfigured=true を目安にする
#
# RDS: users.subscription_status（v8）・users.stripe_customer_id（v10）が必要
#   cd backend && npm run db:migrate-v8 && npm run db:migrate-v10
#
# Webhook 詳細ログ（ECS のタスク環境変数でも可）: STRIPE_WEBHOOK_DEBUG_LOG=1 または true
#
# 緊急デバッグ（受信経路の確認）— 検証後すぐ無効化:
#   STRIPE_WEBHOOK_SKIP_SIGNATURE_VERIFY=1 … 署名検証をスキップし JSON をそのまま処理。stripe.webhook_entry / stripe.webhook_insecure_full_payload が CloudWatch に出る
#   STRIPE_WEBHOOK_DEBUG_BODY_MAX_CHARS=200000 … 全文ログの最大文字数（既定 200000）
# 署名エラー時だけ本文先頭をログ（検証は継続）:
#   STRIPE_WEBHOOK_LOG_PAYLOAD_ON_SIG_FAIL=1
#
# ALB が API_PATH_PREFIX=/api でパスを正規化している場合、Stripe の …/api/stripe/webhook はアプリ側では POST /stripe/webhook にマッチする（コード対応済み）。
#
# --- ログイン時 Stripe 同期（users.subscription_stripe_synced_at に依存 → npm run db:migrate-v47）---
# 既定でログイン・GET /auth/me のたびに（スロットル付き）Stripe API で Subscription を取得し families を更新する。
# STRIPE_SESSION_SUBSCRIPTION_SYNC=0 … 無効化
# STRIPE_SESSION_SYNC_INTERVAL_SECONDS=900 … 同一ユーザーが再度 Stripe を叩くまでの最短秒数（既定 900）
# GET /auth/me?stripeSync=1 … 上記スロットルを無視して Stripe 取得（設定画面がフロントから付与）
#
# --- CloudWatch（ECS 本番）---
# ロググループは Terraform で /ecs/kakeibo-api（name_prefix 既定）。リージョンは ap-northeast-1（東京）。
# コンソールで us-east-1 を開いているとロググループが 0 件に見えるのでリージョンを合わせる。
# docker-compose は未使用。コンテナは `node src/index.js`（stdout/stderr を awslogs が収集）。
#
# Logs Insights（ロググループ /ecs/kakeibo-api、リージョン東京）— @message は 1 行 JSON
#
# 1) 起動だけ
#   fields @timestamp, @message
#   | filter @message like /"event":"boot"/
#   | sort @timestamp desc
#
# 2) エラー全般
#   fields @timestamp, @message
#   | filter @message like /"level":"error"/ or @message like /uncaught_exception/ or @message like /listen_failed/ or @message like /WebhookHandlerError/
#
# 3) Stripe Webhook（ルーティング到達の最短確認: signature 前でも出る）
#   fields @timestamp, @message
#   | filter @message like /stripe\.webhook_entry/ or @message like /stripe\.event_received/ or @message like /checkout_link_summary/ or @message like /subscription_sync_db/
#   | sort @timestamp desc
#
# 4) 署名失敗
#   fields @timestamp, @message | filter @message like /signature_invalid|InvalidSignature/
#
# SIGTERM のみが並ぶ場合はデプロイでの旧タスク停止が多い。直前に boot.listen_bound や local-server.started が出ているか確認する。
#
# ローカルで Stripe CLI から Webhook を流す（署名検証のため Vite プロキシではなく API 直叩き）
#   1) 別ターミナル: cd backend && npm run dev:api  （既定ポート 3456。API_PORT を変えたら下も合わせる）
#   2) stripe login
#   3) npm run stripe:listen  または npm run stripe:listen:alias（パス …/api/stripe/webhook）
#      または: stripe listen --forward-to http://127.0.0.1:3456/api/webhooks/stripe
#   4) CLI が表示する whsec_... を STRIPE_WEBHOOK_SECRET に設定してから API を再起動
#
# CLI なしで署名付き POST（ダミーイベント）:
#   STRIPE_WEBHOOK_SELFTEST_USER_ID=<users.id> npm run stripe:webhook:selftest
#   customer.subscription.created を試す（checkout より先に届くケースの再現）:
#     bash: STRIPE_WEBHOOK_SELFTEST_EVENT=customer.subscription.created STRIPE_WEBHOOK_SELFTEST_USER_ID=1 npm run stripe:webhook:selftest
#     PowerShell: $env:STRIPE_WEBHOOK_SELFTEST_EVENT="customer.subscription.created"; $env:STRIPE_WEBHOOK_SELFTEST_USER_ID="1"; npm run stripe:webhook:selftest
#   任意: STRIPE_WEBHOOK_SELFTEST_URL=http://127.0.0.1:3456/kakeibo/api/stripe/webhook
#   本番 whsec を使うと本番 DB が更新される。検証後は CLI のテスト用 whsec に戻す。

# --- Amazon Textract（POST /receipts/parse）---
# App Runner では実行ロールに textract:AnalyzeExpense を付与。AWS_REGION はプラットフォームが設定することが多い。
# 未設定時は ap-northeast-1 をフォールバック（textract-receipt.mjs）。
# AWS_REGION=ap-northeast-1
# IAMユーザーキー利用時は次を設定（ECSロール利用時は不要）
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_SESSION_TOKEN=
#
# 既定で S3 経由 AnalyzeExpense を使用（TEXTRACT_USE_S3=true）。
# レシート画像を一時配置するバケット（必須）
# TEXTRACT_SOURCE_S3_BUCKET=your-textract-source-bucket
# 互換エイリアス（上記が未設定のとき参照）:
# TEXTRACT_S3_BUCKET=
# RECEIPT_SOURCE_S3_BUCKET=
# AWS_S3_BUCKET=
# S3_BUCKET=
# さらに最後のフォールバック（固定既定を使いたい場合）:
# TEXTRACT_SOURCE_S3_BUCKET_DEFAULT=
# 任意: 一時オブジェクトのプレフィックス
# TEXTRACT_SOURCE_S3_PREFIX=receipts/raw
# S3経由を使わず Bytes 直送する場合のみ false
# TEXTRACT_USE_S3=true
#
# ローカルで Textract を呼ばないときは false
# TEXTRACT_ENABLED=false
#
# TEXTRACT_TIMEOUT_MS=25000
# TEXTRACT_MAX_IMAGE_BYTES=5242880
# TEXTRACT_MAX_ATTEMPTS=2
# getaddrinfo EBUSY 等の一時ネットワーク異常時の送信リトライ回数
# TEXTRACT_SEND_RETRIES=2

# --- Amazon Bedrock（POST /ai/advisor・レシート名寄せ POST /receipts/resolve-suggested-vendor）---
# 店名名寄せも同一の Bedrock。外部地図 API キーは不要。本番は ECS タスクロール、ローカルは AWS プロファイル等の認証。
# ECS/ローカルとも、呼び出し元と同じリージョンに合わせる（東京なら ap-northeast-1）。
BEDROCK_REGION=ap-northeast-1
# 任意。未設定時はコード既定で次を順に試行（いずれも AWS 公式 model ID）:
#   1) Claude Sonnet 4.6 … global. / {us|eu|apac}. / anthropic.claude-sonnet-4-6
#   2) Claude 3.7 Sonnet … {geo}. / anthropic.claude-3-7-sonnet-20250219-v1:0
#   3) Claude 3.5 Sonnet v2 … {geo}. / anthropic.claude-3-5-sonnet-20241022-v2:0
#   4) Claude 3.5 Sonnet v1（レガシー・リージョンにより EOL）… anthropic.claude-3-5-sonnet-20240620-v1:0
# コンソールのモデル詳細に表示される ID をそのまま BEDROCK_MODEL_ID に指定すると最優先。
# AccessDeniedException のとき: タスクロールに bedrock:InvokeModel / Converse と、
#   対象モデル（foundation-model/* および inference-profile/*）のリソースが含まれているか確認。
# BEDROCK_MODEL_ID=
# 呼び出し直前の modelId を stdout に出す: BEDROCK_DEBUG_LOG=1
# Bedrock 失敗時にルール応答の代わりにエラー詳細を JSON reply に載せる（本番は通常オフ）: AI_ADVISOR_DEBUG_ERRORS=1
