# Lambda ローカル実行・マイグレーション用。コピーして .env にリネームしパスワードを記入。
# テーブル作成: このフォルダで npm install → npm run db:schema

RDS_HOST=database-1.ch2yqsmikcdn.ap-northeast-1.rds.amazonaws.com
RDS_PORT=3306
RDS_USER=admin
RDS_DATABASE=database-1
RDS_PASSWORD=

# カンマ区切りで複数可。全許可は * （本番はフロントのオリジンを列挙。パスは含めない）
# 本番 SPA: https://ksystemapp.com/kakeibo/ → Origin は https://ksystemapp.com のみ
CORS_ORIGIN=https://ksystemapp.com,http://localhost:5173,http://127.0.0.1:5173
# 未設定時、RDS_HOST が *.rds.amazonaws.com なら TLS を自動有効化
RDS_SSL=

# ローカル API（npm run dev:api）
API_PORT=3456
NODE_ENV=development

# 認証（本番では強力なランダム文字列を必ず設定）
JWT_SECRET=change-me-in-production-use-long-random
JWT_EXPIRES_IN=7d
# 開発のみ: X-User-Id ヘッダーを許可
ALLOW_X_USER_ID=true
# 開発のみ: パスワードリセット・招待トークンを JSON に含める
AUTH_DEBUG_TOKEN=false

# --- Amazon Textract（POST /receipts/parse）---
# App Runner では実行ロールに textract:AnalyzeExpense を付与。AWS_REGION はプラットフォームが設定することが多い。
# 未設定時は ap-northeast-1 をフォールバック（textract-receipt.mjs）。
# AWS_REGION=ap-northeast-1
#
# ローカルで Textract を呼ばないときは false
# TEXTRACT_ENABLED=false
#
# TEXTRACT_TIMEOUT_MS=25000
# TEXTRACT_MAX_IMAGE_BYTES=5242880
# TEXTRACT_MAX_ATTEMPTS=2
# getaddrinfo EBUSY 等の一時ネットワーク異常時の送信リトライ回数
# TEXTRACT_SEND_RETRIES=2

# --- Amazon Bedrock（POST /ai/advisor）---
# Bedrock リージョン（モデルが利用可能なリージョンに合わせる。例: us-east-1, ap-northeast-1）
BEDROCK_REGION=us-east-1
# モデルIDは Bedrock コンソールの「モデルアクセス」で有効化した ID を指定。
# 例: anthropic.claude-3-5-sonnet-20240620-v1:0 / anthropic.claude-sonnet-4-20250514-v1:0
# オンデマンド非対応のモデルは list-inference-profiles の us.xxx 等の推論プロファイル ID が必要な場合あり。
BEDROCK_MODEL_ID=anthropic.claude-3-5-sonnet-20240620-v1:0
